# Ignore all files in the public directory except for index.html
/public/*
!/public/index.html

# Ignore all files in the src directory except for index.js
/src/*
!/src/index.js

# Ignore all files in the config directory except for default.json
/config/*
!/config/default.json

# Ignore all files in the scripts directory except for start.sh
/scripts/*
!/scripts/start.sh

# Ignore all files in the tests directory except for test.js
/tests/*
!/tests/test.js

# Ignore all files in the docs directory except for README.md
/docs/*
!/docs/README.md